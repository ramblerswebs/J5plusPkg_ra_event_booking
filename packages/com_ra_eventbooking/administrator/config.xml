<?xml version="1.0" encoding="utf-8"?>

<config addfieldprefix="Ramblers\Component\Ra_eventbooking\Administrator\Field">
    <fieldset label="Basic settings" name="ra_eventbooking" description="Basic configuration options" >
    
        <field name="total_places" 
               first="0" last="200" step="1" 
               type="integer"
               label="Total number of Places" 
               description="Total or maximum number of places or zero if unlimited places" 
        />  
        <field name="attendeetype" 
               type="list" 
               filter="raw"
               label="Who can attend?" 
               description="Is event open to the public or just members" 
        >
            <option value="memonly">Members Only</option>
            <option value="public">Non members welcome</option>
        </field>
        <field name="waitinglist" 
               type="list" 
               filter="raw"
               label="COM_RA_EVENTBOOKING_FORM_LBL_WAITINGLIST" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_WAITINGLIST" 
               hint="COM_RA_EVENTBOOKING_FORM_LBL_WAITINGLIST"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>
    <fieldset label="User Access" name="user" description="User(logged on) Access">
        <field name="maxattendees" 
               first="1" last="10" step="1" 
               type="integer" 
               label="COM_RA_EVENTBOOKING_FORM_LBL_MAXATTENDEES" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_MAXATTENDEES" 
               hint="COM_RA_EVENTBOOKING_FORM_LBL_MAXATTENDEES"
        />
        <field name="userlistvisibletousers" 
               type="list" 
               label="COM_RA_EVENTBOOKING_FORM_LBL_USERLISTVISIBLETOUSERS" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_USERLISTVISIBLETOUSERS" 
               hint="COM_RA_EVENTBOOKING_FORM_LBL_USERLISTVISIBLETOUSERS"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>
    <fieldset label="Guest Access" name="ra_eventbooking2" description="Non logged user access to booking">
        <field name="guest" 
               type="list" 
               filter="raw"
               default="0" 
               label="COM_RA_EVENTBOOKING_FORM_LBL_GUEST" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_GUEST" 
               hint="COM_RA_EVENTBOOKING_FORM_LBL_GUEST"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="telephone_required" 
               type="list" 
               filter="raw"
               default="1" 
               showon="guest:1"
               label="Guest telephone number" 
               description="Should input of telephone number be required for guest users" 
               hint="Should input of telephone number be required for guest users"
        >
            <option value="0">Optional</option>
            <option value="1">Mandatory</option>
        </field>
        <field name="maxguestattendees" 
               first="1" last="10" step="1" 
               type="integer" 
               showon="guest:1"
               label="COM_RA_EVENTBOOKING_FORM_LBL_MAXGUESTATTENDEES" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_MAXGUESTATTENDEES" 
               hint="COM_RA_EVENTBOOKING_FORM_LBL_MAXGUESTATTENDEES"/>
        <field 
            name="userlistvisibletoguests" 
            type="radio"
            showon="guest:1" 
            layout="joomla.form.field.radio.switcher"
            label="COM_RA_EVENTBOOKING_FORM_LBL_USERLISTVISIBLETOGUESTS" 
            description="COM_RA_EVENTBOOKING_FORM_DESC_USERLISTVISIBLETOGUESTS" 
            hint="COM_RA_EVENTBOOKING_FORM_LBL_USERLISTVISIBLETOGUESTS"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>
    <fieldset label="Payments" name="ra_payments" description="Payments">
        <field name="payment_required" 
               type="list" 
               label="COM_RA_EVENTBOOKING_FORM_LBL_EVENTSETTING_PAYMENT_REQUIRED" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_EVENTSETTING_PAYMENT_REQUIRED" 
               hint="COM_RA_EVENTBOOKING_FORM_LBL_EVENTSETTING_PAYMENT_REQUIRED"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="payment_details" 
               showon="payment_required:1"
               height="250"
               filter="safehtml" 
               type="editor" 
               label="COM_RA_EVENTBOOKING_FORM_LBL_EVENTSETTING_PAYMENT_DETAILS" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_EVENTSETTING_PAYMENT_DETAILS" 
               hint="Description of what payment is required."
        >
            <editor-options>
                <option name="startup_mode">design</option>  <!-- Forces visual mode -->
            </editor-options>
        </field>
    </fieldset>
   
    <fieldset name="communications" description="Communication options" label="Communications">
        <field name="booking_contact_id" 
               type="Bookingcontact" 
               context="config"
               label="COM_RA_EVENTBOOKING_FORM_LBL_GROUP_CONTACT" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_GROUP_CONTACT" 
        />
        <field name="email_booking" 
               type="list" 
               default="individual" 
               label="Booking notifications" 
               description="Send info to booking contact when booking/waiting list changes" 
        >
            <option value="none">No notifications</option>
            <option value="individual">Send copy of booking change emails</option>
            <option value="list">Send booking list email after each change</option>
        </field>
        <field name="notrecommended" 
                 type="note" 
                 label="Not recommended" 
                 showon="email_booking:list"
                 description="This option is not production ready, it currently takes a long time to send the emails" 
                 class="alert alert-info" />
        <field name="email_waiting" 
               showon="email_booking:individual,list"
               type="list" 
               default="0" 
               label="Which changes" 
               description="Include waiting list changes as well as booking changes " 
        >
            <option value="0">Booking changes</option>
            <option value="1">Booking and waiting list changes</option>
        </field>
       
        <field name="email_format" 
               type="text" 
               label="COM_RA_EVENTBOOKING_FORM_LBL_GROUP_EMAIL_FORMAT" 
               description="COM_RA_EVENTBOOKING_FORM_DESC_GROUP_EMAIL_FORMAT" 
               hint="COM_RA_EVENTBOOKING_FORM_LBL_GROUP_EMAIL_FORMAT"
        />
        <field name="customsignature" 
               type="list" 
               filter="raw"
               label="Custom email signature" 
               description="Have a custom signature on all emails" 
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="signature" 
               showon="customsignature:1"
               height="250"
               type="editor"
               filter="safehtml" 
               label="Email Signature" 
               description="Signature to use in place of default" 
               hint="Signature to use in place of default"
        >
            <editor-options>
                <option name="startup_mode">design</option>  <!-- Forces visual mode -->
            </editor-options>
        </field>
        <field name="closingoption" 
               type="list"        
               label="COM_RA_EVENTBOOKING_FORM_LBL_USERLISTCLOSING"
               description="COM_RA_EVENTBOOKING_FORM_DESC_USERLISTCLOSING">
            <option value="start">When event starts</option>
            <option value="6pm">6pm on the day before event</option>
            <option value="6pmweek">6pm on a week before event</option>
            <option value="7am">7am on the day</option>
            <option value="7amweek">7am a week before</option>
            <option value="custom">Custom</option>
        </field>
        <field name="customclosingdate" 
               showon="closingoption:custom"
               type="calendar" 
               showtime="true"
               default="NOW" 
               label="Set Closing date" 
               description="This is when the bookings for events will end" 
               format="%Y-%m-%d %H:%M:%S"
        />

        <field name="send_booking_list_onclosed" 
               type="list" 
               label="Send booking list when closed" 
               description="An email, containing the booking list, will be automatically sent to the Booking Contacts once the booking has closed." 
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="task_comment" 
               type="note" 
               label="Set up task" 
               showon="send_booking_list_onclosed:1"
               description="For this option to work a scheduled task must be set up, see Users Guide for details" 
               class="alert alert-info" />
 
    </fieldset>
    
    <fieldset name="permissions" description="JCONFIG_PERMISSIONS_DESC" label="JCONFIG_PERMISSIONS_LABEL">
        <field name="rules" 
               type="rules" 
               component="com_ra_eventbooking" 
               class="inputbox" 
               filter="rules" validate="rules" 
               label="JCONFIG_PERMISSIONS_LABEL" section="component" 
        />
    </fieldset>
      
</config>